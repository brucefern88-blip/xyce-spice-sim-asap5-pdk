+ kp     = 63.0u
+ lambda = 0.08
+ tox    = 1.0n
+ cgso   = 8.7e-11
+ cgdo   = 8.7e-11
+ tnom   = 25

.subckt nfet_5nm d g s b
mn1 d g s b _nfet_n5_ss w=92n l=16n ad=0 as=0 pd=0 ps=0
Cd_jn d b 0.02f
Cs_jn s b 0.02f
.ends nfet_5nm

.subckt pfet_5nm d g s b
mp1 d g s b _pfet_n5_ss w=92n l=16n ad=0 as=0 pd=0 ps=0
Cd_jn d b 0.02f
Cs_jn s b 0.02f
.ends pfet_5nm

.endl ss


