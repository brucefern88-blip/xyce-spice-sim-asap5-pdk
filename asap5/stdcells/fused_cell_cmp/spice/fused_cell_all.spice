echo ""
echo "========================================================"
echo "  POWER ANALYSIS"
echo "========================================================"
meas tran iavg_a avg i(vdd_a) from=0 to=1.6000e-08
meas tran iavg_e avg i(vdd_e) from=0 to=1.6000e-08
meas tran iavg_f avg i(vdd_f) from=0 to=1.6000e-08
meas tran iavg_g avg i(vdd_g) from=0 to=1.6000e-08

echo ""
echo "--- Per-cell power at VDD=0.5V ---"
let pwr_a = abs(iavg_a) * 0.5
print pwr_a
let pwr_e = abs(iavg_e) * 0.5
print pwr_e
let pwr_f = abs(iavg_f) * 0.5
print pwr_f
let pwr_g = abs(iavg_g) * 0.5
print pwr_g

echo ""
echo "========================================================"
echo "  PROPAGATION DELAY (OH1 critical path)"
echo "========================================================"
meas tran td_a_oh1 trig v(bi) val=0.25 rise=1 targ v(a_oh1) val=0.25 rise=1
meas tran td_e_oh1 trig v(bi) val=0.25 rise=1 targ v(e_oh1) val=0.25 rise=1
meas tran td_f_oh1 trig v(bi) val=0.25 rise=1 targ v(f_oh1) val=0.25 rise=1
meas tran td_g_noh1 trig v(bi) val=0.25 rise=1 targ v(g_noh1) val=0.25 fall=1

quit
.endc

.end