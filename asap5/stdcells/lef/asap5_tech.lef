VERSION 5.8 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

UNITS
  DATABASE MICRONS 1000 ;
END UNITS

MANUFACTURINGGRID 0.001 ;

# ============================================================================
# ASAP5 / TSMC N5 Technology LEF
# Updated: 12 routing metals (M1-M12) + 11 via layers
# RC values calibrated to TSMC N5 5nm FinFET metal stack
#
# Metal Tiers:
#   Local (M1-M3):      28nm pitch, 14nm width, 36nm thick
#   Intermediate (M4-M6): 40nm pitch, 20nm width, 40nm thick
#   Semi-global (M7-M8): 80nm pitch, 40nm width, 60nm thick
#   Global (M9-M10):    160nm pitch, 80nm width, 100nm thick
#   Top power (M11-M12): 800nm pitch, 400nm width, 800nm thick
#
# RPERSQ = R_per_μm × Width_μm
# CPERSQDIST = C_per_μm / Width_μm (effective area capacitance)
# ============================================================================

# --- Local interconnect: M1-M3 ---

LAYER M1
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.028 ;
  WIDTH 0.014 ;
  SPACING 0.014 ;
  RESISTANCE RPERSQ 0.560 ;
  CAPACITANCE CPERSQDIST 0.02000 ;
  THICKNESS 0.036 ;
END M1

LAYER V1
  TYPE CUT ;
  SPACING 0.014 ;
  WIDTH 0.014 ;
END V1

LAYER M2
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.028 ;
  WIDTH 0.014 ;
  SPACING 0.014 ;
  RESISTANCE RPERSQ 3.150 ;
  CAPACITANCE CPERSQDIST 0.01929 ;
  THICKNESS 0.036 ;
END M2

LAYER V2
  TYPE CUT ;
  SPACING 0.014 ;
  WIDTH 0.014 ;
END V2

LAYER M3
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.028 ;
  WIDTH 0.014 ;
  SPACING 0.014 ;
  RESISTANCE RPERSQ 1.386 ;
  CAPACITANCE CPERSQDIST 0.01571 ;
  THICKNESS 0.036 ;
END M3

LAYER V3
  TYPE CUT ;
  SPACING 0.014 ;
  WIDTH 0.014 ;
END V3

# --- Intermediate interconnect: M4-M6 ---

LAYER M4
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.040 ;
  WIDTH 0.020 ;
  SPACING 0.020 ;
  RESISTANCE RPERSQ 2.340 ;
  CAPACITANCE CPERSQDIST 0.01000 ;
  THICKNESS 0.040 ;
END M4

LAYER V4
  TYPE CUT ;
  SPACING 0.020 ;
  WIDTH 0.020 ;
END V4

LAYER M5
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.040 ;
  WIDTH 0.020 ;
  SPACING 0.020 ;
  RESISTANCE RPERSQ 1.040 ;
  CAPACITANCE CPERSQDIST 0.01300 ;
  THICKNESS 0.040 ;
END M5

LAYER V5
  TYPE CUT ;
  SPACING 0.020 ;
  WIDTH 0.020 ;
END V5

LAYER M6
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.040 ;
  WIDTH 0.020 ;
  SPACING 0.020 ;
  RESISTANCE RPERSQ 0.320 ;
  CAPACITANCE CPERSQDIST 0.00800 ;
  THICKNESS 0.040 ;
END M6

LAYER V6
  TYPE CUT ;
  SPACING 0.020 ;
  WIDTH 0.020 ;
END V6

# --- Semi-global interconnect: M7-M8 ---

LAYER M7
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.080 ;
  WIDTH 0.040 ;
  SPACING 0.040 ;
  RESISTANCE RPERSQ 0.440 ;
  CAPACITANCE CPERSQDIST 0.00425 ;
  THICKNESS 0.060 ;
END M7

LAYER V7
  TYPE CUT ;
  SPACING 0.040 ;
  WIDTH 0.040 ;
END V7

LAYER M8
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.080 ;
  WIDTH 0.040 ;
  SPACING 0.040 ;
  RESISTANCE RPERSQ 0.440 ;
  CAPACITANCE CPERSQDIST 0.00425 ;
  THICKNESS 0.060 ;
END M8

LAYER V8
  TYPE CUT ;
  SPACING 0.040 ;
  WIDTH 0.040 ;
END V8

# --- Global interconnect: M9-M10 ---

LAYER M9
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.160 ;
  WIDTH 0.080 ;
  SPACING 0.080 ;
  RESISTANCE RPERSQ 0.880 ;
  CAPACITANCE CPERSQDIST 0.00238 ;
  THICKNESS 0.100 ;
END M9

LAYER V9
  TYPE CUT ;
  SPACING 0.080 ;
  WIDTH 0.080 ;
END V9

LAYER M10
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.160 ;
  WIDTH 0.080 ;
  SPACING 0.080 ;
  RESISTANCE RPERSQ 0.032 ;
  CAPACITANCE CPERSQDIST 0.00438 ;
  THICKNESS 0.100 ;
END M10

LAYER V10
  TYPE CUT ;
  SPACING 0.080 ;
  WIDTH 0.080 ;
END V10

# --- Top-level power: M11-M12 ---

LAYER M11
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;
  PITCH 0.800 ;
  WIDTH 0.400 ;
  SPACING 0.400 ;
  RESISTANCE RPERSQ 0.160 ;
  CAPACITANCE CPERSQDIST 0.00088 ;
  THICKNESS 0.800 ;
END M11

LAYER V11
  TYPE CUT ;
  SPACING 0.400 ;
  WIDTH 0.400 ;
END V11

LAYER M12
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.800 ;
  WIDTH 0.400 ;
  SPACING 0.400 ;
  RESISTANCE RPERSQ 0.160 ;
  CAPACITANCE CPERSQDIST 0.00088 ;
  THICKNESS 0.800 ;
END M12

# ============================================================================
# VIA DEFINITIONS
# ============================================================================

VIA V1_1x1 DEFAULT
  LAYER M1 ;
    RECT -0.007 -0.007 0.007 0.007 ;
  LAYER V1 ;
    RECT -0.007 -0.007 0.007 0.007 ;
  LAYER M2 ;
    RECT -0.007 -0.007 0.007 0.007 ;
END V1_1x1

VIA V2_1x1 DEFAULT
  LAYER M2 ;
    RECT -0.007 -0.007 0.007 0.007 ;
  LAYER V2 ;
    RECT -0.007 -0.007 0.007 0.007 ;
  LAYER M3 ;
    RECT -0.007 -0.007 0.007 0.007 ;
END V2_1x1

VIA V3_1x1 DEFAULT
  LAYER M3 ;
    RECT -0.007 -0.007 0.007 0.007 ;
  LAYER V3 ;
    RECT -0.007 -0.007 0.007 0.007 ;
