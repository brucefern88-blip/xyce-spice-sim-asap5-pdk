    RECT -0.010 -0.010 0.010 0.010 ;
END V6_1x1

VIA V7_1x1 DEFAULT
  LAYER M7 ;
    RECT -0.020 -0.020 0.020 0.020 ;
  LAYER V7 ;
    RECT -0.020 -0.020 0.020 0.020 ;
  LAYER M8 ;
    RECT -0.020 -0.020 0.020 0.020 ;
END V7_1x1

VIA V8_1x1 DEFAULT
  LAYER M8 ;
    RECT -0.020 -0.020 0.020 0.020 ;
  LAYER V8 ;
    RECT -0.020 -0.020 0.020 0.020 ;
  LAYER M9 ;
    RECT -0.020 -0.020 0.020 0.020 ;
END V8_1x1

VIA V9_1x1 DEFAULT
  LAYER M9 ;
    RECT -0.040 -0.040 0.040 0.040 ;
  LAYER V9 ;
    RECT -0.040 -0.040 0.040 0.040 ;
  LAYER M10 ;
    RECT -0.040 -0.040 0.040 0.040 ;
END V9_1x1

VIA V10_1x1 DEFAULT
  LAYER M10 ;
    RECT -0.040 -0.040 0.040 0.040 ;
  LAYER V10 ;
    RECT -0.040 -0.040 0.040 0.040 ;
  LAYER M11 ;
    RECT -0.040 -0.040 0.040 0.040 ;
END V10_1x1

VIA V11_1x1 DEFAULT
  LAYER M11 ;
    RECT -0.200 -0.200 0.200 0.200 ;
  LAYER V11 ;
    RECT -0.200 -0.200 0.200 0.200 ;
  LAYER M12 ;
    RECT -0.200 -0.200 0.200 0.200 ;
END V11_1x1

# ============================================================================
# VIA GENERATE RULES
# ============================================================================

VIARULE V1_1x1_rule GENERATE
  LAYER M1 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER M2 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER V1 ;
    RECT -0.007 -0.007 0.007 0.007 ;
    SPACING 0.028 BY 0.028 ;
END V1_1x1_rule

VIARULE V2_1x1_rule GENERATE
  LAYER M2 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER M3 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER V2 ;
    RECT -0.007 -0.007 0.007 0.007 ;
    SPACING 0.028 BY 0.028 ;
END V2_1x1_rule

VIARULE V3_1x1_rule GENERATE
  LAYER M3 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER M4 ;
    ENCLOSURE 0.000 0.000 ;
  LAYER V3 ;
    RECT -0.007 -0.007 0.007 0.007 ;
    SPACING 0.028 BY 0.028 ;
END V3_1x1_rule

