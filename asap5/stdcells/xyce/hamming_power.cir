.TRAN 0.1n 5000.0n

.PRINT TRAN V(hd[0]) V(hd[1]) V(hd[2]) V(hd[3]) V(hd[4]) V(hd[5]) V(hd[6])
+ V(oh0[0]) V(oh1[0]) V(oh2[0]) V(oh0[16]) V(oh1[16]) V(oh2[16])
+ V(A[0]) V(B[0]) V(A[1]) V(B[1]) I(Vvdd)

.MEASURE TRAN i_avg AVG I(Vvdd) FROM=0n TO=5000.0n
.MEASURE TRAN i_rms RMS I(Vvdd) FROM=0n TO=5000.0n
.MEASURE TRAN p_avg AVG {V(VDD)*I(Vvdd)} FROM=0n TO=5000.0n
.MEASURE TRAN p_peak MAX {V(VDD)*I(Vvdd)} FROM=0n TO=5000.0n

.MEASURE TRAN p_seg0 AVG {V(VDD)*I(Vvdd)} FROM=0.0n TO=500.0n
.MEASURE TRAN p_seg1 AVG {V(VDD)*I(Vvdd)} FROM=500.0n TO=1000.0n
.MEASURE TRAN p_seg2 AVG {V(VDD)*I(Vvdd)} FROM=1000.0n TO=1500.0n
