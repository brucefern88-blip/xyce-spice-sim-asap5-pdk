# Clean up
opt_clean

# Report statistics
stat -liberty /Users/bruce/CLAUDE/asap5/stdcells/lib/asap5_stdcells_tt_0p5v_25c.lib

# Write output
write_verilog -noattr /Users/bruce/CLAUDE/asap5/stdcells/n5_integration/scripts/synth_out.v
