  /* BUFx1: Non-inverting buffer (2x INVx1) for ABC compatibility */
  cell (BUFx1) {
    area : 14000;
    cell_footprint : "BUFx1";
    cell_leakage_power : 1.00;

    pg_pin (VDD) {
      voltage_name : VDD;
      pg_type : primary_power;
    }
    pg_pin (VSS) {
      voltage_name : VSS;
      pg_type : primary_ground;
    }

    pin (A) {
      direction : input;
      capacitance : 0.070;
      max_transition : 0.500;
    }

    pin (Y) {
      direction : output;
      function : "A";
      max_capacitance : 10.000;
      max_transition : 0.500;

      timing () {
        related_pin : "A";
        timing_sense : positive_unate;

        cell_rise (scalar) { values ("0.188"); }
        cell_fall (scalar) { values ("0.146"); }
        rise_transition (scalar) { values ("0.200"); }
        fall_transition (scalar) { values ("0.180"); }
      }

      internal_power () {
        related_pin : "A";
        rise_power (scalar) { values ("0.010"); }
        fall_power (scalar) { values ("0.008"); }
      }
    }
  }

