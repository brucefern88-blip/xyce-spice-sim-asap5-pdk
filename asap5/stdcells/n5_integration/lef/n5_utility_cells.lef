# --- DECAPx2: Decoupling capacitor cell ---
# Purpose: Power supply decoupling for noise reduction
# 2 sites wide for meaningful capacitance
MACRO DECAPx2
  CLASS CORE ;
  ORIGIN 0 0 ;
  SIZE 0.088 BY 0.140 ;
  SYMMETRY X Y ;
  SITE asap5_site ;

  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER M1 ;
        RECT 0.000 0.126 0.088 0.140 ;
      LAYER M1 ;
        RECT 0.014 0.070 0.074 0.126 ;
    END
  END VDD

  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER M1 ;
        RECT 0.000 0.000 0.088 0.014 ;
      LAYER M1 ;
        RECT 0.014 0.014 0.074 0.070 ;
    END
  END VSS
END DECAPx2

END LIBRARY
