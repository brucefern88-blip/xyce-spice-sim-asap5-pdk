VERSION 5.8 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

# ============================================================================
# ASAP5/N5 Utility Cells for OpenLane2 P&R Flow
# Process: ASAP5 5nm GAA Nanosheet (N5-compatible dimensions)
# Site: asap5_site (44nm x 140nm)
# Generated for OpenLane2 integration — fills, taps, ties, endcaps, decaps
# ============================================================================

# --- FILLx1: 1-site filler cell ---
# Purpose: Fill empty spaces in placement rows
# No logic, power rails only
MACRO FILLx1
  CLASS CORE ;
  ORIGIN 0 0 ;
  SIZE 0.044 BY 0.140 ;
  SYMMETRY X Y ;
  SITE asap5_site ;

  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER M1 ;
        RECT 0.000 0.126 0.044 0.140 ;
    END
  END VDD

  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER M1 ;
        RECT 0.000 0.000 0.044 0.014 ;
    END
  END VSS

  OBS
    LAYER M1 ;
      RECT 0.000 0.014 0.044 0.126 ;
  END
END FILLx1

